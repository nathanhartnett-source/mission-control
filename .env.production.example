# Mission Control — production env template (clean-build / single-tenant)
# Copy to .env.production and fill in. mc-install.sh writes these automatically
# on a fresh install.

# Client mode: hides admin's multi-agent list, shows only the single user agent.
MC_CLIENT_MODE=1

# Display name for the user agent (e.g. "Roxy", "Atlas").
MC_AGENT_NAME=Assistant

# Site/brand name shown in the header.
MC_BRAND_NAME=Mission Control

# Path to the agent runner script (OBT-style runner is installed here by mc-install.sh).
MC_RUNNER_ME=/usr/local/bin/mc-user-agent-runner.sh

# Admin API token — long random string. Required for /api/admin/* and the
# Settings → Updates "Pull & rebuild" button. Rotate any time, then restart.
MC_ADMIN_API_TOKEN=

# Session cookie secret — long random string. Required for login.
SESSION_COOKIE_SECRET=

# Optional: override the wiki root (defaults to $MC_HOME/data/wiki if unset).
# MC_WIKI_ROOT=/root/mission-control/data/wiki
