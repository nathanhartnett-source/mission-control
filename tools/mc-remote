#!/usr/bin/env bash
# mc-remote — call any MC install's admin API from this WSL box.
#
# Used by Discord-Ava (Nathan's tmux REPL) AND MC Ava (per-turn `claude -p`)
# AND Nathan himself, so neither agent has to ask Nathan to copy-paste SSH
# commands for routine ops on OBT or any future client install.
#
# Usage:
#   mc-remote <host>                            # health
#   mc-remote <host> health
#   mc-remote <host> deploy                     # git pull + npm build + restart
#   mc-remote <host> exec '<whitelisted-cmd>'   # safe diagnostic command
#   mc-remote <host> file <path>                # read file (prefix-locked)
#   mc-remote <host> logs [unit]                # tail systemd journal
#
# Hosts are resolved from $MC_REMOTE_HOSTS or this built-in map:
#   obt → https://obt.allhart.com.au
#
# Tokens live at ~/.mc-admin-tokens/<host>.txt (mode 0600). If the file is
# missing the script tells you what to put in it.

set -euo pipefail

HOST="${1:-}"
ACTION="${2:-health}"

if [[ -z "$HOST" ]]; then
    cat <<USAGE
mc-remote <host> [action] [args...]

Actions:
  health                        # quick liveness probe (default)
  deploy                        # git pull + npm build + systemctl restart
  exec '<command>'              # whitelisted diagnostic command
  file <path>                   # read file content
  logs [unit]                   # tail systemd journal (default: mission-control)

Configured hosts:
  obt   → https://obt.allhart.com.au
USAGE
    exit 0
fi

# Resolve host → base URL.
case "$HOST" in
    obt) BASE_URL="https://obt.allhart.com.au" ;;
    *)
        if [[ -n "${MC_REMOTE_HOSTS:-}" ]]; then
            mapfile -t MAPPING <<< "${MC_REMOTE_HOSTS//,/$'\n'}"
            for entry in "${MAPPING[@]}"; do
                key="${entry%%=*}"
                val="${entry#*=}"
                if [[ "$key" == "$HOST" ]]; then
                    BASE_URL="$val"
                    break
                fi
            done
        fi
        if [[ -z "${BASE_URL:-}" ]]; then
            echo "mc-remote: unknown host '$HOST' — add to MC_REMOTE_HOSTS env (host=url[,host=url...]) or extend the case in ~/bin/mc-remote" >&2
            exit 2
        fi
        ;;
esac

TOKEN_FILE="$HOME/.mc-admin-tokens/$HOST.txt"
if [[ ! -s "$TOKEN_FILE" ]]; then
    cat >&2 <<MSG
mc-remote: token file missing at $TOKEN_FILE

To set up:
  ssh into $HOST (or paste from console) and run:
    grep MC_ADMIN_API_TOKEN /root/mission-control/.env.production
  Save the token value to:
    $TOKEN_FILE
  And lock it down:
    chmod 600 $TOKEN_FILE
MSG
    exit 3
fi
TOKEN="$(<"$TOKEN_FILE")"
TOKEN="${TOKEN//[$'\r\n ']/}"

curl_call() {
    local method="$1"; shift
    local path="$1"; shift
    local data="${1:-}"
    if [[ -n "$data" ]]; then
        curl -fsS -X "$method" "$BASE_URL$path" \
            -H "Authorization: Bearer $TOKEN" \
            -H "Content-Type: application/json" \
            -d "$data"
    else
        curl -fsS -X "$method" "$BASE_URL$path" \
            -H "Authorization: Bearer $TOKEN"
    fi
}

case "$ACTION" in
    health)
        curl_call GET /api/admin/api/health
        echo
        ;;
    deploy)
        curl_call POST /api/admin/api/deploy
        echo
        ;;
    exec)
        CMD="${3:-}"
        if [[ -z "$CMD" ]]; then
            echo "usage: mc-remote $HOST exec '<command>'" >&2
            exit 2
        fi
        # JSON-escape via python (safer than ad-hoc sed)
        BODY="$(python3 -c 'import json,sys; print(json.dumps({"cmd": sys.argv[1]}))' "$CMD")"
        curl_call POST /api/admin/api/exec "$BODY"
        echo
        ;;
    file)
        FILE_PATH="${3:-}"
        if [[ -z "$FILE_PATH" ]]; then
            echo "usage: mc-remote $HOST file <path>" >&2
            exit 2
        fi
        BODY="$(python3 -c 'import json,sys; print(json.dumps({"path": sys.argv[1]}))' "$FILE_PATH")"
        curl_call POST /api/admin/api/file "$BODY"
        echo
        ;;
    logs)
        UNIT="${3:-mission-control}"
        BODY="$(python3 -c 'import json,sys; print(json.dumps({"unit": sys.argv[1]}))' "$UNIT")"
        curl_call POST /api/admin/api/logs "$BODY"
        echo
        ;;
    *)
        echo "mc-remote: unknown action '$ACTION'" >&2
        exit 2
        ;;
esac
